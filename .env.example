# Database — PostgreSQL via Neon (REQUIRED)
# Sign up free at https://neon.tech and create a project
# Copy the connection string from Dashboard > Connection Details
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxxxx-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Scraping Configuration
SCRAPE_INTERVAL_HOURS=6
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration (comma-separated list of allowed origins)
# For production, specify your frontend domain(s)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO

# Optional: OpenAI API Key (for future AI enhancements)
# OPENAI_API_KEY=your_openai_api_key_here
